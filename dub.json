{
    "name": "graunde",
    "description": "Workflow enforcement for Claude Code",
    "targetType": "executable",
    "targetName": "graunde",
    "mainSourceFile": "source/main.d",
    "sourcePaths": ["source"],
    "stringImportPaths": ["."],
    "dflags": ["-betterC"],
    "preBuildCommands": ["git describe --tags --always > .version"],
    "configurations": [
        {
            "name": "default",
            "libs": ["sqlite3"],
            "lflags": ["-L/usr/local/opt/sqlite/lib"]
        },
        {
            "name": "nosqlite",
            "dflags": ["-d-version=NoSQLite"]
        }
    ]
}
